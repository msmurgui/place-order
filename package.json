{
  "name": "place-order",
  "version": "1.0.0",
  "description": "POST /orders — production-ready order endpoint",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "dev-for-demo": "RATE_LIMIT_MAX=1000 ts-node src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/db/dataSource.ts",
    "migration:run:prod": "typeorm migration:run -d dist/db/dataSource.js",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/db/dataSource.ts",
    "seed": "ts-node src/db/seeds/run.ts",
    "seed:prod": "node dist/db/seeds/run.js",
    "seed:reset": "ts-node src/db/seeds/truncate.ts && ts-node src/db/seeds/run.ts",
    "seed:reset:prod": "node dist/db/seeds/truncate.js && node dist/db/seeds/run.js",
    "demo": "RATE_LIMIT_MAX=1000 ts-node src/demo/demo.ts",
    "load-test": "RATE_LIMIT_MAX=1000 ts-node src/demo/load-test.ts"
  },
  "dependencies": {
    "@types/swagger-ui-express": "^4.1.8",
    "bullmq": "^5.51.0",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.21",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
